<div class="py-4 sm:py-8">
  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
    <h1>Categories</h1>
    <div class="flex gap-2">
      <%= link_to order_admin_categories_path, class: "btn btn-sm sm:btn-md" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5 7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" />
        </svg>
        <span class="hidden sm:inline">Reorder</span>
      <% end %>
      <%= link_to new_admin_category_path, class: "btn btn-sm sm:btn-md btn-primary" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        <span class="hidden sm:inline">New Category</span>
      <% end %>
    </div>
  </div>

  <%# Desktop Table View %>
  <div class="hidden md:block overflow-x-auto">
    <table class="table table-zebra w-full">
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Slug</th>
          <th>Products</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @categories.each do |category| %>
          <%= render partial: "admin/categories/category_row", locals: { category: category, indent: false } %>
          <% category.children.sort_by(&:position).each do |child| %>
            <%= render partial: "admin/categories/category_row", locals: { category: child, indent: true } %>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Mobile Card View %>
  <div class="md:hidden space-y-3">
    <% @categories.each do |category| %>
      <%= render partial: "admin/categories/category_card", locals: { category: category, indent: false } %>
      <% category.children.sort_by(&:position).each do |child| %>
        <%= render partial: "admin/categories/category_card", locals: { category: child, indent: true } %>
      <% end %>
    <% end %>
  </div>

  <% if @categories.empty? %>
    <div class="text-center py-8 text-base-content/70">
      <p>No categories found.</p>
    </div>
  <% end %>
</div>
