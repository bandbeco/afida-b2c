<div class="overflow-x-auto">
  <table class="table table-zebra w-full">
    <thead>
      <tr class="bg-base-200 text-xs">
        <th class="text-left font-medium uppercase">Product</th>
        <th class="text-left hidden md:table-cell font-medium uppercase">SKU</th>
        <th class="text-right hidden md:table-cell font-medium uppercase">Pack Size</th>
        <th class="text-right font-medium uppercase">Price/Pack</th>
        <th class="text-right hidden lg:table-cell font-medium uppercase">Price/Unit</th>
        <th class="text-center font-medium uppercase">Quantity</th>
        <th class="text-center"></th>
      </tr>
    </thead>
    <tbody>
      <% products.each do |product| %>
        <%= render "row", product: product %>
      <% end %>
    </tbody>
  </table>
</div>

<% if products.empty? %>
  <div class="text-center py-12">
    <p class="text-gray-500">No products found matching your filters.</p>
    <%= link_to "Clear filters", price_list_path, class: "btn btn-outline btn-sm mt-4" %>
  </div>
<% else %>
  <div class="mt-6 flex flex-col items-center gap-2">
    <p class="text-sm text-gray-500">
      Showing <%= pagy.from %>–<%= pagy.to %> of <%= pagy.count %> products
    </p>
    <% if pagy.pages > 1 %>
      <%== pagy.series_nav %>
    <% end %>
  </div>
<% end %>
