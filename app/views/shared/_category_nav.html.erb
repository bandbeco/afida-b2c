<%# Desktop mega-menu category bar (hover-to-open) %>
<%# Replaces old flat category links with dropdown panels showing subcategories %>
<%# Hidden on mobile (< lg breakpoint) — mobile uses hamburger drill-down instead %>

<% categories = @nav_categories %>
<% vegware_collection = @nav_vegware_collection %>
<% vegware_categories = @nav_vegware_categories %>

<div class="category-mega-menu hidden lg:block bg-base-200 border-b border-base-300 relative"
     data-controller="category-mega-menu">

  <div class="container mx-auto px-4 relative z-50">
    <ul class="flex justify-between py-3">
      <% categories.each_with_index do |cat, index| %>
        <li>
          <button type="button"
                  class="flex items-center gap-2 text-sm lg:text-base text-base-content hover:text-primary transition-colors cursor-pointer"
                  data-category-mega-menu-target="trigger"
                  data-action="mouseenter->category-mega-menu#showPanel mouseleave->category-mega-menu#scheduleHide"
                  data-index="<%= index %>"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-controls="category-panel-<%= cat.slug %>">
            <%= category_icon_tag(cat, class: "w-5 h-5 object-contain") %>
            <span><%= cat.name %></span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </li>
      <% end %>

      <% if vegware_collection %>
        <li>
          <button type="button"
                  class="flex items-center gap-2 text-sm lg:text-base text-base-content hover:text-primary transition-colors cursor-pointer"
                  data-category-mega-menu-target="trigger"
                  data-action="mouseenter->category-mega-menu#showPanel mouseleave->category-mega-menu#scheduleHide"
                  data-index="<%= categories.size %>"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-controls="category-panel-vegware">
            <%= category_icon_tag("vegware", class: "w-5 h-5 object-contain") %>
            <span>Vegware</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </li>
      <% end %>
    </ul>
  </div>

  <%# Dropdown panels — JS positions each under its trigger %>
  <% categories.each_with_index do |cat, index| %>
    <div id="category-panel-<%= cat.slug %>"
         class="hidden opacity-0 absolute z-50 pt-2 transition-opacity duration-200 ease-out"
         data-category-mega-menu-target="panel"
         data-action="mouseenter->category-mega-menu#cancelHide mouseleave->category-mega-menu#panelLeave"
         data-index="<%= index %>"
         style="top: 100%;">
      <div class="bg-base-100 rounded-xl shadow-2xl border border-base-200 p-6 min-w-[240px]">
        <nav class="flex flex-col gap-1">
          <% cat.children.order(:position).each do |sub| %>
            <%= link_to category_browse_path(sub),
                        class: "text-base-content hover:text-primary transition-colors py-1" do %>
              <%= sub.name %>
            <% end %>
          <% end %>
        </nav>
        <div class="mt-4 pt-3 border-t border-base-200">
          <%= link_to category_browse_path(cat),
                      class: "text-sm text-base-content/60 hover:text-primary transition-colors" do %>
            View all <%= cat.name %> →
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if vegware_collection %>
    <div id="category-panel-vegware"
         class="hidden opacity-0 absolute z-50 pt-2 transition-opacity duration-200 ease-out"
         data-category-mega-menu-target="panel"
         data-action="mouseenter->category-mega-menu#cancelHide mouseleave->category-mega-menu#panelLeave"
         data-index="<%= categories.size %>"
         style="top: 100%;">
      <div class="bg-base-100 rounded-xl shadow-2xl border border-base-200 p-6 min-w-[240px]">
        <nav class="flex flex-col gap-1">
          <% vegware_categories.each do |cat| %>
            <%= link_to category_filter_collection_path(vegware_collection, category_slug: cat.slug),
                        class: "text-base-content hover:text-primary transition-colors py-1" do %>
              Vegware <%= cat.name %>
            <% end %>
          <% end %>
        </nav>
        <div class="mt-4 pt-3 border-t border-base-200">
          <%= link_to collection_path(vegware_collection),
                      class: "text-sm text-base-content/60 hover:text-primary transition-colors" do %>
            View all Vegware →
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

</div>
