<div data-testid="vegware-stockist-banner"
     data-controller="dismissable-banner"
     data-dismissable-banner-key-value="vegware-stockist"
     class="bg-emerald-700 text-white text-sm py-2.5 hidden"
     data-dismissable-banner-target="banner">
  <div class="container mx-auto px-5 flex items-center justify-center gap-3">
    <%= vite_image_tag "images/logos/vegware.svg",
                        alt: "Vegware",
                        class: "h-5 w-auto brightness-0 invert" %>
    <span>Official Stockist.</span>
    <%= link_to vegware_path, class: "underline underline-offset-2 hover:text-emerald-200 transition-colors" do %>
      Shop the range &rarr;
    <% end %>
    <button type="button"
            data-action="dismissable-banner#dismiss"
            class="ml-2 text-white/70 hover:text-white transition-colors"
            aria-label="Dismiss banner">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
</div>
