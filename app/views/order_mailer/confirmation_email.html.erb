<table border="0" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td align="center" style="padding: 20px 30px 40px 30px;">
      <h1 style="font-size: 28px; font-weight: 600; color: #111827; margin: 0;">Order confirmed.</h1>
      <p style="color: #374151; font-size: 16px; margin-top: 15px;">
        <strong>Thanks, <%= @order.shipping_name %>.</strong>
        <br>
        <br>
        Your order is in and we're getting it packed.
        <br>
        <br>
        Your order number is <strong style="color: #111827;">#<%= @order.order_number %></strong>.
      </p>
      <a href="<%= order_url(@order, token: @order.signed_access_token) %>" target="_blank" style="display: inline-block; background-color: #76e9bf; color: #000000; padding: 12px 30px; margin-top: 25px; border-radius: 8px; text-decoration: none; font-weight: 500;">
        View Your Order
      </a>
    </td>
  </tr>
  
  <tr>
    <td style="padding: 0 30px;">
      <h2 style="font-size: 20px; font-weight: 600; color: #111827; border-bottom: 2px solid #e5e7eb; padding-bottom: 10px;">Order Summary</h2>
      <table cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-top: 20px;">
        <% @order.order_items.each do |item| %>
          <tr>
            <td style="padding-bottom: 20px;">
              <p style="font-size: 16px; color: #111827; margin: 0; font-weight: 600;">
                <%= item.quantity %>x <%= item.product_name %>
                <% if item.sample? %>
                  <span style="color: #059669; font-weight: 500; font-size: 14px;">(Sample)</span>
                <% end %>
              </p>
            </td>
            <td align="right" style="padding-bottom: 20px;">
              <p style="font-size: 16px; color: #111827; margin: 0;"><%= item.sample? ? "FREE" : number_to_currency(item.line_total, unit: "£") %></p>
            </td>
          </tr>
        <% end %>
      </table>
    </td>
  </tr>

  <tr>
    <td style="padding: 20px 30px;">
      <%# Lines, order, labels, amounts and the discount rule come from
          OrdersHelper#order_summary_lines (shared with the storefront pages, the
          admin page and the ops email); this template only supplies email-safe
          inline-styled rows. %>
      <table cellspacing="0" cellpadding="0" border="0" width="100%" style="border-top: 2px solid #e5e7eb; padding-top: 20px;">
        <% order_summary_lines(@order).each do |line| %>
          <% if line[:kind] == :total %>
            <tr style="font-weight: 600;">
              <td style="padding-top: 15px;"><p style="font-size: 18px; color: #111827; margin: 0;"><%= line[:label] %></p></td>
              <td align="right" style="padding-top: 15px;"><p style="font-size: 18px; color: #111827; margin: 0;"><%= line[:amount] %></p></td>
            </tr>
          <% else %>
            <tr>
              <td style="padding-top: 8px;"><p style="font-size: 16px; color: #374151; margin: 0;"><%= line[:label] %></p></td>
              <td align="right" style="padding-top: 8px;"><p style="font-size: 16px; color: <%= line[:negative] ? "#059669" : "#111827" %>; margin: 0;"><%= line[:amount] %></p></td>
            </tr>
          <% end %>
        <% end %>
      </table>
    </td>
  </tr>

  <tr>
    <td align="center" style="padding: 40px 30px;">
      <p style="color: #6b7280; font-size: 14px;">Thanks for choosing Afida. We appreciate it.</p>
    </td>
  </tr>
</table>