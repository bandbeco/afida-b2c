<% content_for :breadcrumbs do %>
  <%= render "shared/breadcrumbs", category: @category %>
<% end %>

<% content_for :title do %>
<%= @category.meta_title.presence || "#{@category.name} | Afida" %>
<% end %>

<% content_for :meta_description do %>
<%= @category.meta_description %>
<% end %>

<% if @category.image.attached? %>
  <% content_for :og_image, rails_storage_proxy_url(@category.image) %>
<% end %>

<% content_for :og_tags_custom, true %>
<% content_for :twitter_tags_custom, true %>
<% content_for :head do %>
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= @category.meta_title.presence || "#{@category.name} | Afida" %>">
  <meta property="og:description" content="<%= @category.meta_description %>">
  <meta property="og:url" content="<%= category_browse_url(@category) %>">
  <meta property="og:site_name" content="Afida">
  <meta property="og:image" content="<%= @category.image.attached? ? rails_storage_proxy_url(@category.image) : hero_image_url %>">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= @category.meta_title.presence || "#{@category.name} | Afida" %>">
  <meta name="twitter:description" content="<%= @category.meta_description %>">

  <script type="application/ld+json">
    <%
      breadcrumb_items = [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": root_url }
      ]
      if @category.parent.present?
        breadcrumb_items << { "@type": "ListItem", "position": 2, "name": @category.parent.name, "item": category_url(@category.parent) }
        breadcrumb_items << { "@type": "ListItem", "position": 3, "name": @category.name, "item": category_browse_url(@category) }
      else
        breadcrumb_items << { "@type": "ListItem", "position": 2, "name": @category.name, "item": category_browse_url(@category) }
      end
    %>
    <%= raw({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": @category.name,
      "description": @category.description,
      "url": category_browse_url(@category),
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumb_items
      }
    }.to_json) %>
  </script>
<% end %>

<div class="drawer drawer-end">
  <input id="cart-drawer" type="checkbox" class="drawer-toggle" aria-label="Toggle shopping cart" />
  <div class="drawer-content">

<%# Hero Section %>
<section class="category-hero rounded-2xl overflow-hidden mb-8 <%= @category.image.attached? ? 'grid md:grid-cols-2 gap-0' : '' %>">
  <div class="p-6 md:p-10 flex flex-col justify-center bg-base-200">
    <h1 class="text-4xl mb-3 flex items-center gap-3">
      <% if category_icon_path(@category).present? %>
        <%= vite_image_tag category_icon_path(@category), class: 'w-10 h-10 object-contain', alt: "#{@category.name} icon" %>
      <% end %>
      <%= @category.name %>
    </h1>
    <% if @category.description.present? %>
      <p class="text-base-content/70 text-lg mb-4"><%= @category.description %></p>
    <% end %>
    <p class="text-base-content/60"><%= "Browse #{@products.size}+ #{@category.name.downcase}" %></p>
  </div>
  <% if @category.image.attached? %>
    <div class="hidden md:block relative overflow-hidden">
      <%= image_tag @category.image, class: "absolute inset-0 w-full h-full object-contain", alt: @category.name %>
    </div>
  <% end %>
</section>

<div class="min-h-[60vh]">
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    <%= render partial: "products/card", collection: @products, as: :product %>
  </div>
</div>

<%# Buying Guide Section %>
<% if @category.buying_guide.present? %>
  <section class="buying-guide mt-12 py-8 border-t border-base-300">
    <div class="prose max-w-none">
      <%= render_markdown(@category.buying_guide) %>
    </div>
  </section>

  <%= buying_guide_structured_data(@category) %>
<% end %>

<%# Category FAQs Section %>
<% category_faqs = @category.faqs.presence || [] %>
<% if category_faqs.any? %>
  <section class="mt-12 py-8 border-t border-base-300 flex flex-col items-center">
    <h2 class="text-2xl mb-6">Frequently Asked Questions About <%= @category.name %></h2>
    <div class="join join-vertical w-full max-w-3xl">
      <% category_faqs.each do |faq| %>
        <div class="collapse collapse-arrow join-item bg-base-100 border border-base-300">
          <input type="radio" name="category-faq" aria-label="<%= faq["question"] %>" />
          <h3 class="collapse-title text-lg"><%= faq["question"] %></h3>
          <div class="collapse-content">
            <p class="text-base-content/70 leading-relaxed pt-2"><%= render_faq_answer(faq["answer"]) %></p>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%= category_faq_schema_markup(category_faqs) %>
<% end %>

<%# Related Categories Section - "You Might Also Need" %>
<% related_cats = related_categories_for(@category) %>
<% if related_cats.any? %>
  <div class="mt-12 py-8 border-t border-base-300">
    <h2 class="text-2xl mb-2">You Might Also Need</h2>
    <p class="text-base-content/70 mb-6">Complete your order with these complementary products.</p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <% related_cats.each do |related_category| %>
        <%= link_to category_browse_path(related_category), class: "card bg-base-100 border border-base-300 hover:border-primary hover:shadow-md transition-all" do %>
          <div class="card-body flex-row items-center gap-4 p-4">
            <% if category_icon_path(related_category).present? %>
              <%= vite_image_tag category_icon_path(related_category), class: 'w-12 h-12 object-contain', alt: "#{related_category.name} icon" %>
            <% end %>
            <div>
              <h3 class="card-title text-base"><%= related_category.name %></h3>
              <p class="text-sm text-base-content/60"><%= pluralize(related_category.products_count, "product") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-auto text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

  </div>

  <div class="drawer-side">
    <label for="cart-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
    <div class="bg-base-200 text-base-content h-full w-80 p-4 flex flex-col">
      <%= render "shared/drawer_cart_content" %>
    </div>
  </div>
</div>