<div class="flex flex-wrap justify-center gap-4 md:gap-6" data-controller="scroll-reveal" data-scroll-reveal-stagger-value="60">
  <% @categories.each_with_index do |category, index| %>
    <%= link_to category_browse_path(category), class: "group flex flex-col overflow-hidden border-2 border-black rounded-2xl shadow-xl w-[calc(50%-0.5rem)] md:w-[calc(20%-1.2rem)]" do %>
      <!-- Image area -->
      <div class="relative aspect-square overflow-hidden" style="background-color: <%= category_pastel_color(index) %>">
        <% if category.image.attached? %>
          <%= image_tag category.image.variant(
                resize_to_fill: [400, 400],
                format: :webp,
                saver: { quality: 80 }
              ), alt: category.name, class: "w-full h-full object-cover transition-transform duration-300 group-hover:scale-105",
              loading: "lazy" %>
        <% elsif category_icon_path(category).present? %>
          <div class="w-full h-full flex items-center justify-center p-6 transition-transform duration-300 group-hover:scale-105">
            <%= vite_image_tag category_icon_path(category), class: 'w-full h-full object-contain opacity-80', alt: "#{category.name} icon" %>
          </div>
        <% else %>
          <div class="w-full h-full flex items-center justify-center transition-transform duration-300 group-hover:scale-105">
            <span class="text-7xl font-black text-[#79ebc0]/20"><%= category.name[0] %></span>
          </div>
        <% end %>
      </div>

      <!-- Footer -->
      <div class="bg-afida-green px-3 py-2.5 flex items-center justify-center">
        <span class="text-black text-sm md:text-base whitespace-nowrap truncate"><%= category.name %></span>
      </div>
    <% end %>
  <% end %>
</div>