<% content_for :title, "Custom Branded Coffee Cups | Your Brand, Your Cup | Afida" %>

<% content_for :meta_description, "Design your own custom branded double wall coffee cups. No setup fees, UK production, delivered in 20 business days. Start from just 1,000 units." %>

<% content_for :og_image, vite_asset_url('images/branding.webp') %>

<% content_for :og_tags_custom, true %>
<% content_for :twitter_tags_custom, true %>
<% content_for :head do %>
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Custom Branded Coffee Cups | Your Brand, Your Cup | Afida">
  <meta property="og:description" content="Design your own custom branded double wall coffee cups. No setup fees, UK production, delivered in 20 business days.">
  <meta property="og:url" content="<%= branding_url %>">
  <meta property="og:site_name" content="Afida">
  <meta property="og:image" content="<%= vite_asset_url('images/branding.webp') %>">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Custom Branded Coffee Cups | Your Brand, Your Cup | Afida">
  <meta name="twitter:description" content="Design your own custom branded double wall coffee cups. No setup fees, UK production, delivered in 20 business days.">
  <meta name="twitter:image" content="<%= vite_asset_url('images/branding.webp') %>">

  <!-- Structured Data: Service -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Custom Branded Coffee Cups",
      "description": "Design your own custom branded double wall coffee cups with no setup fees, UK production, and delivery in 20 business days.",
      "provider": {
        "@type": "Organization",
        "name": "Afida",
        "url": "<%= root_url %>"
      },
      "areaServed": {
        "@type": "Country",
        "name": "United Kingdom"
      },
      "serviceType": "Custom Printing",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "GBP",
        "eligibleQuantity": {
          "@type": "QuantitativeValue",
          "minValue": 1000,
          "unitText": "units"
        }
      }
    }
  </script>

  <!-- Structured Data: Breadcrumb -->
  <script type="application/ld+json">
    <%= breadcrumb_structured_data([
      { name: "Home", url: root_url },
      { name: "Branding", url: branding_url }
    ]).html_safe %>
  </script>
<% end %>

<!-- Hero Section -->
<section class="w-screen relative left-[50%] right-[50%] -mx-[50vw] bg-neutral-900 overflow-hidden">
  <!-- Subtle dot pattern background -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 24px 24px;"></div>

  <!-- Decorative glows -->
  <div class="absolute -top-20 -right-20 w-96 h-96 bg-[#79ebc0] rounded-full blur-[140px] opacity-15"></div>
  <div class="absolute -bottom-20 -left-20 w-72 h-72 bg-[#79ebc0] rounded-full blur-[120px] opacity-10"></div>

  <div class="container mx-auto px-4 py-16 lg:py-24 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <h1 class="text-white">
          Unbranded Cups?<br>
          <span class="text-[#79ebc0]">In This Economy?</span>
        </h1>

        <p class="text-lg text-gray-300 mb-6 leading-relaxed max-w-xl mx-auto lg:mx-0">
          Every cup that walks out your door is a tiny billboard. Yours are currently blank. Your logo, your cups, your napkins, printed beautifully, delivered fast, no setup fees.
        </p>

        <!-- Trust Badges (inline) -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mb-12">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 text-sm font-medium text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            Low MOQs
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 text-sm font-medium text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
            </svg>
            High Quality Printing
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 text-sm font-medium text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
            Free Storage
          </span>
        </div>

        <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4 mb-8">
          <%= link_to branded_products_path, class: "btn btn-primary btn-lg" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            Start Branding
          <% end %>
          <%= link_to contact_path, class: "btn btn-outline btn-lg border border-white/20 text-white hover:bg-white/10 hover:border-white/40" do %>
            Have Questions?
          <% end %>
        </div>
      </div>

      <!-- Photo Collage Grid -->
      <% collage = branding_collage_images %>
      <div class="grid grid-cols-6 grid-rows-5 gap-2 sm:gap-3 h-[350px] sm:h-[400px] lg:h-[450px]">
        <% if collage %>
          <% grid_classes = [
            "col-span-2 row-span-5",
            "col-span-2 row-span-2",
            "col-span-2 row-span-5",
            "col-span-2 row-span-3"
          ] %>
          <% collage.each_with_index do |branding_image, i| %>
            <div class="<%= grid_classes[i] %> group overflow-hidden rounded-2xl">
              <%= image_tag branding_image.image, alt: branding_image.alt_text,
                  class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
            </div>
          <% end %>
        <% else %>
          <div class="col-span-2 row-span-5 group overflow-hidden rounded-2xl">
            <%= vite_image_tag "images/branding/DSC_6621.webp",
                alt: "Shakedown branded coffee cup",
                class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
          </div>
          <div class="col-span-2 row-span-2 group overflow-hidden rounded-2xl">
            <%= vite_image_tag "images/branding/DSC_6736.webp",
                alt: "OOO Koffee branded cup",
                class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
          </div>
          <div class="col-span-2 row-span-5 group overflow-hidden rounded-2xl">
            <%= vite_image_tag "images/branding/DSC_6770.webp",
                alt: "La Gelatiera branded gelato cup",
                class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
          </div>
          <div class="col-span-2 row-span-3 group overflow-hidden rounded-2xl">
            <%= vite_image_tag "images/branding/DSC_6898.webp",
                alt: "Branded cup detail",
                class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- How It Works -->
<section class="w-screen relative left-[50%] right-[50%] -mx-[50vw] bg-neutral-950 overflow-hidden">
  <!-- Decorative glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-[#79ebc0] rounded-full blur-[200px] opacity-[0.06]"></div>

  <div class="container mx-auto px-4 py-16 lg:py-24 relative z-10" data-controller="scroll-reveal" data-scroll-reveal-self-value="true">
    <div class="text-center mb-12">
      <h2 class="text-white">From Design to Doorstep</h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">Get your branded cups in three simple steps</p>
    </div>

    <div class="relative max-w-5xl mx-auto">
      <!-- Connector line spanning steps 1-3 (hidden on mobile) -->
      <div class="hidden md:block absolute top-8 left-[16.67%] right-[16.67%] border-t border-dashed border-white/10"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="relative">
          <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center mb-6 text-2xl font-black text-[#79ebc0] relative z-10">
              1
            </div>
            <h3 class="text-white">Design</h3>
            <p class="text-gray-400">Upload your logo. Preview it in real time. Takes about as long as making a coffee.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative">
          <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center mb-6 text-2xl font-black text-[#79ebc0] relative z-10">
              2
            </div>
            <h3 class="text-white">Order</h3>
            <p class="text-gray-400">Add to cart. Check out. No quote requests. No "we'll get back to you." Just a price and a button.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative">
          <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center mb-6 text-2xl font-black text-[#79ebc0] relative z-10">
              3
            </div>
            <h3 class="text-white">Receive</h3>
            <p class="text-gray-400">Printed and delivered in 20 business days. Then watch your cups walk around town with your name on them.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-12">
      <%= link_to branded_products_path, class: "btn btn-primary btn-lg" do %>
        Start Branding
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      <% end %>
    </div>
  </div>
</section>

<!-- Product Showcase Gallery -->
<section class="w-screen relative left-[50%] right-[50%] -mx-[50vw] bg-neutral-900 overflow-hidden">
  <!-- Subtle dot pattern background -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 24px 24px;"></div>

  <!-- Decorative glows -->
  <div class="absolute -top-32 -left-32 w-80 h-80 bg-[#79ebc0] rounded-full blur-[140px] opacity-10"></div>
  <div class="absolute -bottom-32 -right-32 w-80 h-80 bg-[#79ebc0] rounded-full blur-[140px] opacity-10"></div>

  <div class="container mx-auto px-4 py-16 lg:py-24 relative z-10" data-controller="scroll-reveal" data-scroll-reveal-self-value="true">
    <div class="text-center mb-12">
      <h2 class="text-white">Proof We're Not Making This Up.</h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">Real logos. Real cups. Real businesses that stopped handing out anonymous packaging.</p>
    </div>

    <% gallery = branding_gallery_images %>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 max-w-6xl mx-auto">
      <% if gallery %>
        <% gallery.each do |branding_image| %>
          <div class="group relative overflow-hidden rounded-2xl">
            <%= image_tag branding_image.image, alt: branding_image.alt_text, class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
          </div>
        <% end %>
      <% else %>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_6621.webp", alt: "Shakedown branded coffee cup", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_6736.webp", alt: "OOO Koffee branded cup", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_6770.webp", alt: "La Gelatiera branded gelato cup", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_6872.webp", alt: "Collection of branded cups", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_7193.webp", alt: "La Gelatiera branded cups display", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_7239.webp", alt: "Branded gelato cups with gelato", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_6898.webp", alt: "Branded cup detail", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_7110.webp", alt: "Branded cups arrangement", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
        <div class="group relative overflow-hidden rounded-2xl">
          <%= vite_image_tag "images/branding/DSC_7159.webp", alt: "Branded cups display", class: "w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-500" %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Why Choose Us -->
<section class="w-screen relative left-[50%] right-[50%] -mx-[50vw] bg-neutral-900 overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class="border-t border-white/10 grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-white/10" data-controller="scroll-reveal" data-scroll-reveal-self-value="true">
      <!-- Low MOQs -->
      <div class="px-6 sm:px-8 py-8 sm:py-10">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg mb-1 text-white">Low MOQs</h3>
            <p class="text-sm text-gray-400 leading-relaxed">Start at 1,000 units. Because "minimum 50,000" is not a real minimum, it's a hostage situation.</p>
          </div>
        </div>
      </div>

      <!-- High Quality Printing -->
      <div class="px-6 sm:px-8 py-8 sm:py-10">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg mb-1 text-white">High Quality Printing</h3>
            <p class="text-sm text-gray-400 leading-relaxed">Crisp, vibrant printing. Your logo will look better on our cups than it does on your website.</p>
          </div>
        </div>
      </div>

      <!-- Free Storage -->
      <div class="px-6 sm:px-8 py-8 sm:py-10">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg mb-1 text-white">Free Storage</h3>
            <p class="text-sm text-gray-400 leading-relaxed">We store your stock for free. Order in bulk, request deliveries when you need them. Your stockroom can go back to being a stockroom.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Social Proof: Client Logos -->
<%= render "pages/partials/client_logos" %>

<!-- Final CTA -->
<section class="w-screen relative left-[50%] right-[50%] -mx-[50vw] -mb-16 bg-neutral-900 overflow-hidden">
  <!-- Decorative glows -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-[#79ebc0] rounded-full blur-[200px] opacity-[0.08]"></div>

  <div class="container mx-auto px-4 py-16 lg:py-24 relative z-10" data-controller="scroll-reveal" data-scroll-reveal-self-value="true">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-white">Still Reading? Just Go Design Something.</h2>
      <p class="text-xl text-gray-400 mb-8">
        The configurator takes 2 minutes. We take 20 business days. Your customers take photos for Instagram. Everybody wins.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to branded_products_path, class: "btn btn-primary btn-lg" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
          Start Branding
        <% end %>
        <%= link_to contact_path, class: "btn btn-outline btn-lg border border-white/20 text-white hover:bg-white/10 hover:border-white/40" do %>
          Have questions? Contact us
        <% end %>
      </div>
    </div>
  </div>
</section>
