<!-- Eco Maniacs Range -->
<section class="py-8 sm:py-12">
  <div class="container mx-auto px-4">
    <div class="bg-gray-100 rounded-3xl overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 items-center">
        <div class="px-8 sm:px-12 lg:px-16 py-12 sm:py-16">
          <h2 class="!text-3xl sm:!text-4xl !mb-4">Eco Maniacs<br>Bio Fibre Straws</h2>
          <p class="text-base text-gray-600 mb-10 leading-relaxed max-w-md">
            100% biodegradable. Strong as plastic. Won't go soggy in your drink. The paper straw era is over.
          </p>

          <% if @featured_straw_product.present? %>
            <%= link_to product_path(@featured_straw_product), class: "btn btn-primary btn-lg" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
              Shop Bio Fibre Straws
            <% end %>
          <% else %>
            <%= link_to category_path("straws"), class: "btn btn-primary btn-lg" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
              Shop Straws
            <% end %>
          <% end %>
        </div>

        <div class="p-4 sm:p-6">
          <div class="aspect-square rounded-2xl overflow-hidden">
            <%= vite_image_tag "images/bambigga.webp", alt: "Bambigga Bio Fibre Straws", class: "w-full h-full object-cover" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
