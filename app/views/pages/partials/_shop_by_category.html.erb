<section aria-label="Product categories">
  <div class="container mx-auto px-4 py-8 sm:py-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="!text-3xl sm:!text-4xl !mb-0">Shop by category</h2>
      <%= link_to shop_path, class: "btn btn-primary" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path></svg>
        Shop all
      <% end %>
    </div>
    <%= render "categories/index" %>
  </div>
</section>