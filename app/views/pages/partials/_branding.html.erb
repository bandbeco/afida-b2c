<!-- Branding Section -->
<section class="py-4 sm:py-6 lg:py-8" id="branding" data-controller="scroll-reveal" data-scroll-reveal-self-value="true">
  <div class="container mx-auto px-4">
    <div class="bg-neutral-900 text-white overflow-hidden rounded-3xl relative">
      <!-- Subtle dot pattern background -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 24px 24px;"></div>

      <!-- Decorative glow -->
      <div class="absolute -top-20 -right-20 w-72 h-72 bg-[#79ebc0] rounded-full blur-[120px] opacity-15"></div>
      <div class="absolute -bottom-20 -left-20 w-56 h-56 bg-[#79ebc0] rounded-full blur-[100px] opacity-10"></div>

      <div class="relative z-10">
        <!-- Top: Collage + Headline side by side -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">

          <!-- Left: Photo Collage -->
          <% collage = branding_collage_images %>
          <div class="grid grid-cols-2 grid-rows-4 gap-2 sm:gap-3 p-4 sm:p-6 h-[400px] sm:h-[480px] lg:h-[520px]">
            <% if collage %>
              <%# Dynamic collage from admin-uploaded branding images %>
              <% grid_classes = [
                "col-span-1 row-span-4",
                "col-span-1 row-span-2",
                "col-span-1 row-span-2"
              ] %>
              <% collage.first(3).each_with_index do |branding_image, i| %>
                <div class="<%= grid_classes[i] %> group overflow-hidden rounded-2xl">
                  <%= image_tag branding_image.image.variant(
                        resize_to_fill: [600, 800],
                        format: :webp,
                        saver: { quality: 80 }
                      ), alt: branding_image.alt_text,
                      class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500",
                      loading: "lazy" %>
                </div>
              <% end %>
            <% else %>
              <%# Static fallback images %>
              <div class="col-span-1 row-span-4 group overflow-hidden rounded-2xl">
                <%= vite_image_tag "images/branding/DSC_6621.webp",
                    alt: "Shakedown branded coffee cup",
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              </div>
              <div class="col-span-1 row-span-2 group overflow-hidden rounded-2xl">
                <%= vite_image_tag "images/branding/DSC_6736.webp",
                    alt: "OOO Koffee branded cup",
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              </div>
              <div class="col-span-1 row-span-2 group overflow-hidden rounded-2xl">
                <%= vite_image_tag "images/branding/DSC_6770.webp",
                    alt: "La Gelatiera branded gelato cup",
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              </div>
            <% end %>
          </div>

          <!-- Right: Headline + CTA -->
          <div class="flex flex-col justify-center px-6 sm:px-10 lg:px-12 py-10 lg:py-16">
            <p class="text-3xl sm:text-4xl lg:text-5xl font-normal leading-tight mb-1 text-white" role="heading" aria-level="2">
              Your Logo.
            </p>
            <p class="text-3xl sm:text-4xl lg:text-5xl font-normal leading-tight mb-6 text-[#79ebc0]">
              On Things People Hold.
            </p>

            <p class="text-lg sm:text-xl text-gray-300 mb-10 leading-relaxed max-w-lg">
              Custom-printed cups, boxes, and napkins. Beats a Facebook ad and costs less too.
            </p>

            <%= link_to branded_products_path, class: "btn btn-primary btn-lg w-fit" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
              Start Branding
            <% end %>
          </div>
        </div>

        <!-- Bottom: Trust Badges strip -->
        <div class="border-t border-white/10 grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-white/10">
          <!-- Low MOQs -->
          <div class="px-6 sm:px-8 py-6 sm:py-8">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
              <div>
                <h4 class="font-normal text-white mb-1">Low MOQs</h4>
                <p class="text-sm text-gray-400 leading-relaxed">Start at 1,000 units. Because "minimum 50,000" is not a real minimum, it's a hostage situation.</p>
              </div>
            </div>
          </div>

          <!-- High Quality Printing -->
          <div class="px-6 sm:px-8 py-6 sm:py-8">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
                </svg>
              </div>
              <div>
                <h4 class="font-normal text-white mb-1">High Quality Printing</h4>
                <p class="text-sm text-gray-400 leading-relaxed">Crisp, vibrant printing. Your logo will look better on our cups than it does on your website.</p>
              </div>
            </div>
          </div>

          <!-- Free Storage -->
          <div class="px-6 sm:px-8 py-6 sm:py-8">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#79ebc0]/15 border border-[#79ebc0]/30 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#79ebc0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                </svg>
              </div>
              <div>
                <h4 class="font-normal text-white mb-1">Free Storage</h4>
                <p class="text-sm text-gray-400 leading-relaxed">We store your stock for free. Order in bulk, request deliveries when you need them. Your stockroom can go back to being a stockroom.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
