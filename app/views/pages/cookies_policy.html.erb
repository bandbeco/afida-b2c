<% content_for :title, "Cookies Policy | Afida" %>

<% content_for :meta_description, "Learn how Afida uses cookies and similar technologies on our website, what they do, and how you can manage them in your browser." %>

<div class="bg-gray-50 min-h-screen">
  <div class="container mx-auto px-4 py-8 lg:py-12 max-w-4xl">
    <div class="bg-white border border-gray-200 rounded-lg p-6 lg:p-8 shadow-sm cky-cookie-policy">
      <noscript>
        <p class="text-gray-700 mb-4">
          Our cookies policy is loaded by our consent management platform and requires JavaScript to display. While JavaScript is disabled in your browser, you can read about how we use cookies in section&nbsp;9 of our
          <%= link_to "Privacy Policy", "#{privacy_policy_path}#cookies", class: "text-primary hover:underline" %>.
        </p>
        <p class="text-gray-700">
          For any questions, contact us at
          <a href="mailto:hello@afida.com" class="text-primary hover:underline">hello@afida.com</a>.
        </p>
      </noscript>

      <!-- Start CookieYes cookie policy -->
      <script id="cky-cookie-policy" type="text/javascript" src="https://cdn-cookieyes.com/client_data/4eeb7060c91b60b5615e26c3d7c3b15d/cookie-policy/script.js"></script>
      <!-- End CookieYes cookie policy -->
    </div>
  </div>
</div>
