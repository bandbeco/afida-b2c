<% content_for :title, "Premium Eco-Friendly Catering Supplies | Afida" %>

<% content_for :meta_description, "Discover sustainable catering supplies for your business. Premium quality eco-friendly packaging including pizza boxes, ice cream cups, napkins, and takeaway containers. Fast UK delivery." %>

<% content_for :head do %>
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Premium Eco-Friendly Catering Supplies | Afida">
  <meta property="og:description" content="Discover sustainable catering supplies for your business. Premium quality eco-friendly packaging with fast UK delivery.">
  <meta property="og:url" content="<%= root_url %>">
  <meta property="og:site_name" content="Afida">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Premium Eco-Friendly Catering Supplies | Afida">
  <meta name="twitter:description" content="Discover sustainable catering supplies for your business. Premium quality eco-friendly packaging with fast UK delivery.">
<% end %>

<!-- Hero Section -->
<div class="w-screen relative left-[50%] right-[50%] -mx-[50vw] bg-[#f4fbf8] overflow-hidden">
  <div class="container mx-auto px-4 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
      <div class="max-w-2xl">
        <h1 class="text-3xl lg:text-4xl font-black text-neutral-900 leading-tight mb-6 tracking-tight">
         Eco-friendly catering supplies<br>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00a86b] to-[#79ebc0]">Delivered Fast. Zero Storage Hassle.</span>
        </h1>

        <p class="text-lg text-neutral-600 mb-8 leading-relaxed max-w-lg">
          Supply your restaurant, café, or takeaway with high-quality eco-friendly packaging. From custom branded cups to bamboo straws, we deliver everything you need within 48 hours—with free storage and inventory management included.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <%= link_to shop_path, class: "btn btn-primary" do %>
            Shop Products
          <% end %>
        </div>

        <% logos = [
          "ballie-ballerson.png",
          "edwardian-hotels.svg",
          "hawksmoor.png",
          "hurlingham.png",
          "la-gelateria.png",
          "mandarin-oriental.svg",
          "marriott.svg",
          "pixel-bar.png",
          "royal-lancaster.svg",
          "the-grove.webp",
          "vincenzos.svg"
        ] %>

        <div class="mt-12 flex items-center gap-4 text-sm text-neutral-500 font-medium">
          <div class="flex -space-x-2">
            <% logos.each do |logo| %>
              <div class="w-8 h-8 rounded-full bg-gray-200 border-2 border-white">
                <%= vite_image_tag "images/logos/#{logo}", class: "w-full h-full object-contain" %>
              </div>
            <% end %>
          </div>
          <p>Trusted by 500+ businesses</p>
        </div>
      </div>

        <%= vite_image_tag "images/hero.png", alt: "Branded packaging", class: "w-full h-auto drop-shadow-2xl rounded-2xl" %>
    </div>
  </div>
</div>

<!-- Client Logos Conveyor Belt -->
<div class="w-screen relative left-[50%] right-[50%] -mx-[50vw] bg-white py-16 border-y border-neutral-100">
  <div class="relative">
    <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

    <div class="flex overflow-hidden group">
      <div class="logo-conveyor flex items-center whitespace-nowrap">
        <% logos.each do |logo| %>
          <%= vite_image_tag "images/logos/#{logo}", class: "mx-8 h-12 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300" %>
        <% end %>

        <!-- Duplicate for loop -->
        <% logos.each do |logo| %>
          <%= vite_image_tag "images/logos/#{logo}", class: "mx-8 h-12 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Featured Products -->
<div class="container mx-auto px-4 py-16">
  <div class="text-center mb-16">
    <h2 class="text-4xl md:text-5xl font-bold mb-4">Our Bestsellers</h2>
    <div class="w-24 h-1 bg-[#79ebc0] mx-auto rounded-full"></div>
  </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <% @featured_products.each do |product| %>
        <div class="group bg-white rounded-2xl p-4 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-[#79ebc0]/30 relative">
          <figure class="relative overflow-hidden bg-gray-50 rounded-xl mb-4 aspect-[4/5]">
            <% if product.product_photo.attached? %>
              <%= image_tag product.product_photo.variant(resize_to_limit: [400, 400]),
                  alt: product.name,
                  class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center text-gray-400">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              </div>
            <% end %>
            
            <!-- Quick Add Button -->
            <button class="absolute bottom-4 right-4 bg-white text-black p-3 rounded-full shadow-lg translate-y-full opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 hover:bg-[#79ebc0]">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            </button>
          </figure>
          
          <div class="px-2">
            <h3 class="text-lg font-bold mb-1 text-neutral-900 group-hover:text-[#00a86b] transition-colors">
              <%= link_to product.name, product_path(product) %>
            </h3>
            <p class="text-neutral-500 font-medium"><%= number_to_currency product.active_variants.first&.price %></p>
          </div>
        </div>
      <% end %>
    </div>
</div>

<!-- Featured Product -->
<section class="w-screen relative left-[50%] right-[50%] -mx-[50vw] py-24 bg-neutral-900 text-white overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="order-2 md:order-1">
        <div class="mb-8">
          <%= vite_image_tag "images/ecomaniacs-logo.svg", alt: "Eco Maniacs", class: "w-64 brightness-0 invert" %>
        </div>
        <h3 class="text-4xl font-bold mb-6 text-[#79ebc0]">BIO FIBRE STRAWS</h3>
        <p class="text-lg text-gray-300 mb-8 leading-relaxed">
          Available in both beige and black, our 100% biodegradable, Bio Fibre Straws are as durable as plastic, but with all the eco-friendly credentials. These straws boast a sleek and contemporary design that complements any drink or setting.
        </p>
        
        <div class="flex flex-col gap-6">
          <div class="flex items-start gap-4">
            <div>
              <h4 class="text-xl font-bold mb-2">Fully Biodegradable</h4>
              <p class="text-gray-400">Made from bio fibre, these straws are a sustainable alternative to single-use plastic straws.</p>
            </div>
          </div>
        </div>

        <div class="mt-10">
          <%= link_to "View Product", product_path(Product.find_by(slug: "bio-fibre-straws")), class: "btn btn-primary btn-lg" %>
        </div>
      </div>

      <div class="order-1 md:order-2 relative">
        <div class="aspect-square bg-white/5 rounded-3xl border border-white/10 flex items-center justify-center overflow-hidden backdrop-blur-sm p-8">
          <%= vite_image_tag "images/bambigga.png", alt: "Bambigga Bio Fibre Straws", class: "w-full h-full object-contain drop-shadow-2xl transform hover:scale-110 transition-transform duration-500" %>
        </div>
        <!-- Decorative circle -->
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-[#79ebc0] rounded-full blur-3xl opacity-20"></div>
      </div>
    </div>
  </div>
</section>

<!-- Branding Section -->
<section class="w-screen relative left-[50%] right-[50%] -mx-[50vw] py-24 bg-[#ffb7c5]" id="branding">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="relative group">
        <div class="absolute inset-0 bg-black translate-x-4 translate-y-4 rounded-2xl transition-transform group-hover:translate-x-2 group-hover:translate-y-2"></div>
        <div class="aspect-square bg-white rounded-2xl flex items-center justify-center relative z-10 border-2 border-black overflow-hidden">
          <%= vite_image_tag "images/branding.png", alt: "branding by afida", class: "w-full h-full object-cover" %>
        </div>
      </div>
      
      <div>
        <h2 class="text-6xl font-black text-black mb-8 flex items-center gap-4">
          <span>BRANDING</span>
          <div class="flex items-center gap-4">
            <span class="font-light italic text-4xl font-serif">by</span>
            <div class="w-32"><%= render "shared/logo" %></div>
          </div>
        </h2>
        
        <p class="text-xl text-black mb-6 leading-relaxed font-medium">
          Design increases brand recognition. We custom print on a wide range of our products to help you showcase your brand.
        </p>
        
        <div class="grid grid-cols-3 gap-6 mb-12">
          <!-- Feature 1 -->
          <div class="flex flex-col items-center text-center group cursor-default">
            <div class="w-20 h-20 rounded-full bg-[#79ebc0] border-[3px] border-black flex items-center justify-center mb-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] group-hover:translate-x-[2px] group-hover:translate-y-[2px] group-hover:shadow-none transition-all duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <span class="font-black uppercase text-sm tracking-wide leading-tight">Short Lead<br>Times</span>
          </div>

          <!-- Feature 2 -->
          <div class="flex flex-col items-center text-center group cursor-default">
            <div class="w-20 h-20 rounded-full bg-[#79ebc0] border-[3px] border-black flex items-center justify-center mb-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] group-hover:translate-x-[2px] group-hover:translate-y-[2px] group-hover:shadow-none transition-all duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <span class="font-black uppercase text-sm tracking-wide leading-tight">Low Minimum<br>Orders</span>
          </div>

          <!-- Feature 3 -->
          <div class="flex flex-col items-center text-center group cursor-default">
            <div class="w-20 h-20 rounded-full bg-[#79ebc0] border-[3px] border-black flex items-center justify-center mb-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] group-hover:translate-x-[2px] group-hover:translate-y-[2px] group-hover:shadow-none transition-all duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
            </div>
            <span class="font-black uppercase text-sm tracking-wide leading-tight">Full<br>Colour</span>
          </div>
        </div>

          <%= link_to "Brand your products", branded_products_path, class: "btn btn-primary btn-lg shadow-lg shadow-black/20" %>
      </div>
    </div>
  </div>
</section>

<!-- Categories Section -->
<div class="container mx-auto px-4 py-20">
  <div class="text-center mb-16">
    <h2 class="text-4xl md:text-5xl font-bold mb-4">Shop by Category</h2>
    <div class="w-24 h-1 bg-[#79ebc0] mx-auto rounded-full"></div>
  </div>
  <%= render "categories/index" %>
</div>

<!-- Values Banner -->
<section class="w-screen relative left-[50%] right-[50%] -mx-[50vw] bg-black text-white py-24 -mb-16">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      <!-- Column 1 -->
      <div class="flex flex-col items-center group">
        <div class="mb-8 transform group-hover:scale-110 transition-transform duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5"/><path d="M11 19h8.203a1.83 1.83 0 0 0 1.556-.89 1.784 1.784 0 0 0 0-1.775l-1.226-2.12"/><path d="m14 16-3 3 3 3"/><path d="M8.293 13.596 7.196 9.5 3.1 9.598"/><path d="m9.344 5.811 1.093-1.892A1.83 1.83 0 0 1 11.985 3a1.784 1.784 0 0 1 1.546.888l3.943 6.843"/><path d="m13.378 9.533 4.063 6.843 4.125-7.181"/><path d="M12 3V6"/></svg>
        </div>
        <h3 class="text-3xl font-black mb-6 uppercase tracking-tight">Eco-Friendly</h3>
        <p class="text-neutral-400 leading-relaxed max-w-xs mx-auto font-medium text-sm tracking-wide">
          WE ARE DEDICATED TO PROVIDING SUSTAINABLE, ECO-FRIENDLY PRODUCTS WITHOUT COMPROMISING ON QUALITY.
        </p>
      </div>

      <!-- Column 2 -->
      <div class="flex flex-col items-center group">
        <div class="mb-8 transform group-hover:scale-110 transition-transform duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <h3 class="text-3xl font-black mb-6 uppercase tracking-tight">Customer Service</h3>
        <p class="text-neutral-400 leading-relaxed max-w-xs mx-auto font-medium text-sm tracking-wide">
          EXCEPTIONAL SERVICE IS NOT AN OPTION BUT A NECESSITY, AND WE GO ABOVE AND BEYOND TO ENSURE THIS.
        </p>
      </div>

      <!-- Column 3 -->
      <div class="flex flex-col items-center group">
        <div class="mb-8 transform group-hover:scale-110 transition-transform duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-white"><rect width="16" height="13" x="1" y="5" rx="2" ry="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <h3 class="text-3xl font-black mb-6 uppercase tracking-tight">On Time</h3>
        <p class="text-neutral-400 leading-relaxed max-w-xs mx-auto font-medium text-sm tracking-wide">
          NO WAITING AROUND WITH OUR SPEEDY DELIVERY. WE ENSURE TO DELIVER WITHIN 48 HOURS.
        </p>
      </div>
    </div>
  </div>
</section> 