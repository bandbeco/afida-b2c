<%# The cart summary's discount line, shown between Subtotal and Shipping only when
    a coupon is reducing the total. Rendered both on the cart page and by
    update.turbo_stream.erb (which replaces it whole), so its visibility and value
    always stay in sync with the other totals. %>
<div id="discount_line" class="flex justify-between mb-2 text-sm sm:text-base text-success">
  <% if cart_has_discount?(cart) %>
    <span>Discount (<%= welcome_discount_percentage %>%)</span>
    <span id="discount_amount"><%= cart_discount_display(cart) %></span>
  <% end %>
</div>
