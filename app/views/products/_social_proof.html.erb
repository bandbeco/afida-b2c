<%# Social-proof block on the product detail page.
    Reinforces trust at the moment of purchase decision. %>
<section data-test="product-social-proof" aria-label="Customer trust and testimonials" class="mt-12 py-8 sm:py-10 border-t border-base-200">
  <div class="text-center mb-8">
    <% if defined?(gbp_configured?) && gbp_configured? %>
      <div class="flex justify-center mb-3">
        <%= render "shared/gbp_badge", variant: :footer %>
      </div>
    <% end %>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <div data-test="social-proof-avatar-row" class="flex -space-x-2">
        <% client_logos.reject { |logo| logo == "the-grove.webp" }.first(8).each do |logo| %>
          <div class="w-8 h-8 rounded-full bg-gray-200 border-2 border-white">
            <%= vite_image_tag "images/logos/#{logo}", alt: "#{logo.split('.').first.titleize}", class: "w-full h-full object-contain" %>
          </div>
        <% end %>
      </div>
      <p data-test="social-proof-trust-line" class="text-lg sm:text-xl">
        Trusted by 500+ UK businesses
      </p>
    </div>
    <p data-test="social-proof-customers" class="mt-2 text-sm text-base-content/70">
      Including The Ritz, Marriott, Hawksmoor, Mandarin Oriental and Edwardian Hotels.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">
    <% [
      {
        quote: "We've been using Afida for a few years and they have a great understanding of our business's sustainability needs. The advice and product suggestions are well thought out, pricing competitive, customer service extremely responsive and deliveries are speedily despatched without failure.",
        name: "Mark Holden",
        initials: "MH"
      },
      {
        quote: "This company has been fantastic. They have been perfect with all my order needs with efficiency and excelled in the produce delivered. I highly recommend them moving forward with future orders.",
        name: "Wez Maddocks",
        initials: "WM"
      },
      {
        quote: "Great service, easy delivery and a wide range of products!",
        name: "Ryan Calland-Scoble",
        initials: "RC"
      }
    ].each do |t| %>
      <div data-test="social-proof-testimonial" class="bg-white rounded-2xl p-6 border border-neutral-100">
        <div data-test="social-proof-stars" class="flex items-center gap-1 mb-3">
          <% 5.times do %>
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          <% end %>
        </div>
        <blockquote class="text-neutral-700 mb-4 text-sm leading-relaxed">
          &ldquo;<%= t[:quote] %>&rdquo;
        </blockquote>
        <div data-test="social-proof-attribution" class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-neutral-200 flex items-center justify-center flex-shrink-0">
            <span class="text-sm text-neutral-600"><%= t[:initials] %></span>
          </div>
          <div>
            <p class="text-sm text-neutral-900"><%= t[:name] %></p>
            <p class="text-xs text-neutral-500">Verified Google review</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if gbp_configured? %>
    <div data-test="social-proof-google-link" class="text-center mt-6">
      <%= link_to gbp_profile_url,
                  target: "_blank",
                  rel: "noopener noreferrer",
                  class: "inline-flex items-center gap-1.5 text-sm hover:underline",
                  aria: { label: "Read all Afida reviews on Google. Opens in new tab." } do %>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Read all reviews on Google
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      <% end %>
    </div>
  <% end %>

  <%# Full client-logo conveyor (mirrors the homepage version) %>
  <% logos = client_logos %>
  <% client_name_for = ->(logo) { logo.split('.').first.tr('-', ' ').titleize } %>
  <div data-test="social-proof-logo-conveyor" aria-label="Our clients" class="mt-10">
    <div class="bg-white py-4 sm:py-6 rounded-lg">
      <div class="relative">
        <div class="absolute inset-y-0 left-0 w-16 sm:w-32 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
        <div class="absolute inset-y-0 right-0 w-16 sm:w-32 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

        <div class="flex overflow-hidden">
          <div class="logo-conveyor flex items-center whitespace-nowrap">
            <% logos.each do |logo| %>
              <%= vite_image_tag "images/logos/#{logo}", alt: "#{client_name_for.call(logo)} - Afida client", class: "mx-4 sm:mx-8 h-10 sm:h-12 w-auto object-contain", width: 120, height: 48, loading: "lazy" %>
            <% end %>
            <% logos.each do |logo| %>
              <%= vite_image_tag "images/logos/#{logo}", alt: "#{client_name_for.call(logo)}", role: "presentation", class: "mx-4 sm:mx-8 h-10 sm:h-12 w-auto object-contain", width: 120, height: 48, loading: "lazy" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
