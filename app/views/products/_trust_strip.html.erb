<%# Compact trust strip: one-line social proof near the Add to Cart button.
    Star rating + "Trusted by 500+ UK businesses".
    Stars link to the Google Business Profile when configured. %>
<div data-test="product-trust-strip" class="mt-3 flex items-center justify-center gap-2 text-sm text-base-content/70 flex-wrap">
  <% stars = capture do %>
    <span data-test="trust-strip-stars" class="flex items-center gap-0.5">
      <% 5.times do %>
        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      <% end %>
    </span>
  <% end %>
  <% if gbp_configured? %>
    <%= link_to gbp_profile_url,
                target: "_blank",
                rel: "noopener noreferrer",
                class: "inline-flex items-center gap-1 hover:underline",
                aria: { label: "View Google reviews. Opens in new tab." } do %>
      <%= stars %>
      <span class="text-base-content/80">Rated 5.0 on Google</span>
    <% end %>
  <% else %>
    <%= stars %>
  <% end %>
  <span class="text-base-content/40" aria-hidden="true">·</span>
  <span class="inline-flex items-center gap-1.5">
    <span data-test="trust-strip-avatars" class="flex -space-x-1.5">
      <% client_logos.reject { |logo| logo == "the-grove.webp" }.first(5).each do |logo| %>
        <span class="w-6 h-6 rounded-full bg-gray-200 border-2 border-white flex items-center justify-center overflow-hidden">
          <%= vite_image_tag "images/logos/#{logo}", alt: "#{logo.split('.').first.titleize}", class: "w-full h-full object-contain", loading: "lazy" %>
        </span>
      <% end %>
    </span>
    <span>Trusted by 500+ UK businesses</span>
  </span>
</div>
