<%#
  Product Show Page
  Phase 1: One page per product (formerly variant)

  Uses: quantity-selector controller for simple quantity selection
  Data: @product, @related_products
%>

<% content_for :title do %>
<%= @product.meta_title.presence || "#{@product.generated_title} | #{@product.category.name} | Afida" %>
<% end %>

<% content_for :meta_description do %>
<%= @product.meta_description.presence || @product.description_standard_with_fallback %>
<% end %>

<% if @product&.primary_photo&.attached? %>
  <% content_for :og_image, rails_storage_proxy_url(@product.primary_photo.variant(resize_to_limit: [1200, 630])) %>
<% end %>

<% content_for :og_tags_custom, true %>
<% content_for :twitter_tags_custom, true %>
<% content_for :head do %>
  <!-- Twitter Card meta tags -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= @product.generated_title %>">
  <meta name="twitter:description" content="<%= @product.description_standard_with_fallback %>">
  <% if @product&.primary_photo&.attached? %>
    <meta name="twitter:image" content="<%= rails_storage_proxy_url(@product.primary_photo.variant(resize_to_limit: [1200, 630])) %>">
  <% end %>

  <!-- Open Graph meta tags -->
  <meta property="og:type" content="product">
  <meta property="og:title" content="<%= @product.generated_title %>">
  <meta property="og:description" content="<%= @product.description_standard_with_fallback %>">
  <meta property="og:url" content="<%= polymorphic_url(@product) %>">
  <meta property="og:site_name" content="Afida">
  <% if @product&.primary_photo&.attached? %>
    <meta property="og:image" content="<%= rails_storage_proxy_url(@product.primary_photo.variant(resize_to_limit: [1200, 630])) %>">
  <% end %>
  <meta property="product:price:amount" content="<%= @product.pricing_tiers.present? ? @product.pricing_tiers.first["price"] : @product.price %>">
  <meta property="product:price:currency" content="GBP">

  <script type="application/ld+json">
    <%= raw product_structured_data(@product) %>
  </script>

  <script type="application/ld+json">
    <%= raw breadcrumb_structured_data([
      { name: "Home", url: root_url },
      { name: @product.category.slug == "branded-products" ? "Custom Branded Packaging" : @product.category.name,
        url: @product.category.slug == "branded-products" ? branded_products_url : category_browse_url(@product.category) },
      { name: @product.generated_title, url: product_url(@product) }
    ]) %>
  </script>

  <%# GA4 E-commerce: view_item event %>
  <script>
    <%= ecommerce_view_item_event(@product) %>
  </script>

  <%# DataFast: view_item goal %>
  <script>
    <%= datafast_view_item_goal(@product) %>
  </script>
<% end %>

<% content_for :breadcrumbs do %>
  <%= render "shared/breadcrumbs", product: @product %>
<% end %>

<div class="drawer drawer-end">
  <input id="cart-drawer" type="checkbox" class="drawer-toggle" aria-label="Toggle shopping cart" />

  <div class="drawer-content">
    <div class="container mx-auto min-h-screen py-4 pb-8">

      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

        <%# Image Section %>
        <div class="lg:w-1/2 flex-shrink-0"
             data-controller="product-card-hover"
             data-action="mouseenter->product-card-hover#mouseenter mouseleave->product-card-hover#mouseleave">
          <div class="bg-white rounded-lg overflow-hidden relative">
            <% if @product.vegware? %>
              <%= render "shared/vegware_badge" %>
            <% end %>
            <div class="product-image-container">
              <% if @product.product_photo.attached? %>
                <%= image_tag @product.product_photo.variant(resize_and_pad: [800, 800, { background: [255, 255, 255] }], format: :webp, saver: { quality: 80 }),
                              alt: @product.generated_title,
                              class: "product-image w-full h-auto object-contain",
                              fetchpriority: "high",
                              width: 800,
                              height: 800,
                              data: { product_card_hover_target: "productPhoto" } %>
              <% elsif @product.lifestyle_photo.attached? %>
                <%= image_tag @product.lifestyle_photo.variant(resize_and_pad: [800, 800, { background: [255, 255, 255] }], format: :webp, saver: { quality: 80 }),
                              alt: @product.generated_title,
                              class: "product-image w-full h-auto object-contain",
                              fetchpriority: "high",
                              width: 800,
                              height: 800 %>
              <% end %>

              <% if @product.product_photo.attached? && @product.lifestyle_photo.attached? %>
                <%= image_tag @product.lifestyle_photo.variant(resize_and_pad: [800, 800, { background: [255, 255, 255] }], format: :webp, saver: { quality: 80 }),
                              alt: "#{@product.generated_title} lifestyle",
                              class: "product-image product-image-overlay w-full h-auto object-contain",
                              loading: "lazy",
                              width: 800,
                              height: 800,
                              data: { product_card_hover_target: "lifestylePhoto" } %>
              <% end %>
            </div>
          </div>
        </div>

        <%# Content Section %>
        <% has_tiers = @product.pricing_tiers.present? %>
        <div class="lg:w-1/2 text-center lg:text-left"
             <% if has_tiers %>
               data-controller="pricing-tier sticky-atc"
               data-pricing-tier-tiers-value="<%= @product.pricing_tiers.to_json %>"
               data-pricing-tier-default-price-value="<%= @product.price.to_f %>"
               data-pricing-tier-default-pac-size-value="<%= @product.pac_size || 1 %>"
             <% else %>
               data-controller="quantity-selector sticky-atc"
               data-quantity-selector-price-value="<%= @product.price.to_f %>"
               data-quantity-selector-pac-size-value="<%= @product.pac_size || 1 %>"
             <% end %>>

          <h1 class="text-2xl sm:text-3xl lg:text-4xl">
            <%= @product.generated_title %>
          </h1>

          <%# Price Display %>
          <div class="flex items-center justify-center lg:justify-start gap-2 flex-wrap mt-3">
            <% if has_tiers %>
              <p class="text-xl" data-pricing-tier-target="priceDisplay">
                From <%= number_to_currency(@product.pricing_tiers.first["price"].to_f) %>
              </p>
            <% else %>
              <p class="text-xl">
                <% if @product.pac_size && @product.pac_size > 1 %>
                  <%= number_to_currency(@product.price) %> / pack of <%= number_with_delimiter(@product.pac_size) %>
                <% else %>
                  <%= number_to_currency(@product.price) %>
                <% end %>
              </p>
            <% end %>
          </div>

          <%# SKU %>
          <div class="mt-2">
            <span class="text-sm text-base-content/50 font-mono">
              SKU: <%= @product.sku %>
            </span>
          </div>

          <%# Short Description %>
          <% if @product.description_standard_with_fallback.present? %>
            <p class="text-lg text-gray-700 mt-4">
              <%= @product.description_standard_with_fallback %>
            </p>
          <% end %>

          <% if has_tiers %>
            <%# === Pricing Tier Selector === %>
            <div class="mt-6">
              <label class="block text-lg font-medium mb-3">Select option</label>
              <div class="flex flex-col gap-3" role="listbox" aria-label="Select pack size">
                <% @product.pricing_tiers.each do |tier| %>
                  <div class="border border-gray-200 bg-white rounded-xl px-4 py-3 cursor-pointer hover:border-primary transition grid grid-cols-[1fr_auto] gap-3 items-center"
                       data-pricing-tier-target="tierCard"
                       data-tier-price="<%= tier["price"] %>"
                       data-tier-quantity="<%= tier["quantity"] %>"
                       data-action="click->pricing-tier#selectTier keydown->pricing-tier#handleCardKeydown"
                       role="option"
                       aria-selected="false"
                       tabindex="0">
                    <div>
                      <span class="font-medium"><%= tier["quantity"] >= 100 ? "Case" : "Pack" %> of <%= number_with_delimiter(tier["quantity"]) %></span>
                    </div>
                    <div class="text-right font-medium">
                      <%= number_to_currency(tier["price"].to_f) %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>

            <%# Quantity (how many of selected tier) %>
            <div class="mt-6">
              <label for="quantity" class="block text-lg font-medium mb-2">Quantity</label>
              <div class="flex items-center justify-center lg:justify-start gap-4">
                <div class="join">
                  <button type="button"
                          class="join-item btn btn-outline"
                          data-action="click->pricing-tier#decrement"
                          aria-label="Decrease quantity">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                    </svg>
                  </button>
                  <input type="number"
                         id="quantity"
                         name="quantity"
                         value="1"
                         min="1"
                         max="999"
                         class="join-item input input-bordered w-20 text-center"
                         data-pricing-tier-target="input"
                         data-action="change->pricing-tier#updateTotal"
                         aria-label="Quantity">
                  <button type="button"
                          class="join-item btn btn-outline"
                          data-action="click->pricing-tier#increment"
                          aria-label="Increase quantity">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                  </button>
                </div>
                <span class="text-base-content/60" data-pricing-tier-target="unitsDisplay"></span>
              </div>
            </div>
          <% else %>
            <%# === Standard Quantity Selector (no tiers) === %>
            <div class="mt-6">
              <label for="quantity" class="block text-lg font-medium mb-2">Quantity</label>
              <div class="flex items-center justify-center lg:justify-start gap-4">
                <div class="join">
                  <button type="button"
                          class="join-item btn btn-outline"
                          data-action="click->quantity-selector#decrement"
                          aria-label="Decrease quantity">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                    </svg>
                  </button>
                  <input type="number"
                         id="quantity"
                         name="quantity"
                         value="1"
                         min="1"
                         max="999"
                         class="join-item input input-bordered w-20 text-center"
                         data-quantity-selector-target="input"
                         data-action="change->quantity-selector#updateTotal"
                         aria-label="Quantity">
                  <button type="button"
                          class="join-item btn btn-outline"
                          data-action="click->quantity-selector#increment"
                          aria-label="Increase quantity">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                  </button>
                </div>
                <% if @product.pac_size && @product.pac_size > 1 %>
                  <span class="text-base-content/60" data-quantity-selector-target="unitsDisplay">
                    (<%= number_with_delimiter(@product.pac_size) %> units)
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Custom Inquiry CTA %>
          <div class="mt-6">
            <div class="bg-base-200 rounded-lg p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
              <div>
                <p class="font-sm">Can't find what you're looking for?</p>
                <p class="text-xs">Need a different size, quantity, or material ...</p>
              </div>
              <%= link_to "Get in touch", contact_path, class: "link link-hover underline font-medium whitespace-nowrap" %>
            </div>
          </div>

          <%# Compatible Lids Section (inline, above add to cart) %>
          <% if @compatible_products.present? && @compatible_products.any? %>
            <div class="mt-6"
                 data-controller="compatible-lids"
                 data-compatible-lids-product-id-value="<%= @product.id %>">
              <h3 class="text-lg font-medium mb-2">Add matching lids <span class="text-sm font-normal text-base-content/60">(optional)</span></h3>
              <p class="text-sm text-base-content/70 mb-4">Complete your order with compatible lids</p>

              <div id="lids-loading" class="text-center py-4" style="display:none;">
                <span class="loading loading-spinner loading-md"></span>
              </div>

              <div class="flex flex-col gap-3" data-compatible-lids-target="container">
                <% @compatible_products.each do |lid| %>
                  <div class="bg-white border-2 border-gray-200 rounded-lg hover:border-primary transition-colors p-3 sm:p-4">
                    <div class="flex items-start gap-3 sm:gap-4">
                      <%# Image %>
                      <div class="flex-shrink-0 w-20 h-20 sm:w-24 sm:h-24">
                        <% if lid.primary_photo&.attached? %>
                          <%= image_tag lid.primary_photo.variant(resize_to_limit: [200, 200]),
                                        alt: lid.generated_title,
                                        class: "w-full h-full object-contain",
                                        loading: "lazy" %>
                        <% else %>
                          <div class="w-full h-full bg-gray-100 flex items-center justify-center rounded text-3xl">📦</div>
                        <% end %>
                      </div>

                      <%# Content %>
                      <div class="flex-1 min-w-0">
                        <h4 class="text-base sm:text-lg mb-1 leading-tight">
                          <%= [lid.material, lid.size].compact.join(' · ') %> compatible
                        </h4>
                        <p class="text-sm sm:text-base text-gray-900">
                          <%= number_to_currency(lid.price) %> / pack of <%= number_with_delimiter(lid.pac_size) %>
                        </p>

                        <%# Actions %>
                        <div class="flex flex-col gap-2 mt-3">
                          <select class="w-full px-2 sm:px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent bg-white"
                                  data-lid-quantity="<%= lid.sku %>">
                            <% (1..10).each do |num_packs| %>
                              <% total_units = lid.pac_size * num_packs %>
                              <option value="<%= num_packs %>">
                                <%= num_packs %> <%= num_packs == 1 ? 'pack' : 'packs' %> (<%= number_with_delimiter(total_units) %> units)
                              </option>
                            <% end %>
                          </select>
                          <button type="button"
                                  class="w-full px-3 sm:px-4 py-2 text-sm font-medium text-black bg-primary hover:bg-primary-focus rounded-md transition-colors cursor-pointer"
                                  data-action="click->compatible-lids#addLidToCart"
                                  data-lid-sku="<%= lid.sku %>"
                                  data-lid-name="<%= lid.generated_title %>">
                            Add to Cart
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Order Summary & Add to Cart %>
          <div class="mt-6 space-y-2">
            <div class="flex items-center gap-2 justify-center lg:justify-start text-sm sm:text-base" data-controller="delivery-countdown">
              <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <span>
                Delivery <strong data-delivery-countdown-target="deliveryDate" class="font-semibold"></strong>.
                Order within <span data-delivery-countdown-target="countdown" class="text-green-600 font-medium"></span>.
              </span>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 pt-4 border-t border-base-200">
              <p class="text-base sm:text-lg">Total (excl. VAT)</p>
              <% if has_tiers %>
                <p class="text-xl sm:text-2xl" data-pricing-tier-target="totalDisplay">
                  <%= number_to_currency(@product.pricing_tiers.first["price"].to_f) %>
                </p>
              <% else %>
                <p class="text-xl sm:text-2xl" data-quantity-selector-target="totalDisplay">
                  <%= number_to_currency(@product.price) %>
                </p>
              <% end %>
            </div>
          </div>

          <%# Add to Cart Form %>
          <%= form_with url: cart_cart_items_path,
                        method: :post,
                        id: "add-to-cart-form",
                        data: { controller: "cart-drawer", action: "turbo:submit-end->cart-drawer#open", turbo: true },
                        class: "mt-4" do |f| %>
            <%= hidden_field_tag "cart_item[sku]", @product.sku %>
            <% if has_tiers %>
              <input type="hidden"
                     name="cart_item[quantity]"
                     data-pricing-tier-target="quantityInput"
                     value="1" />
              <input type="hidden"
                     name="cart_item[tier_price]"
                     data-pricing-tier-target="priceInput"
                     value="" />
              <input type="hidden"
                     name="cart_item[tier_pac_size]"
                     data-pricing-tier-target="pacSizeInput"
                     value="" />
              <button type="submit" class="btn btn-primary btn-lg w-full"
                      data-pricing-tier-target="addToCartButton"
                      data-sticky-atc-target="mainButton"
                      disabled>
                Add to Cart
              </button>
            <% else %>
              <input type="hidden"
                     name="cart_item[quantity]"
                     data-quantity-selector-target="quantityInput"
                     value="1" />
              <button type="submit" class="btn btn-primary btn-lg w-full"
                      data-sticky-atc-target="mainButton">
                Add to Cart
              </button>
            <% end %>
          <% end %>

          <p class="text-sm text-base-content/60 text-center mt-3 flex items-center justify-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
            Free delivery over £100
          </p>

          <%# Sticky Add-to-Cart Bar (mobile only) %>
          <div data-sticky-atc-target="stickyBar"
               class="fixed bottom-0 inset-x-0 bg-base-100 border-t border-base-300 px-4 py-3 md:hidden z-40 translate-y-full transition-transform duration-300 ease-in-out">
            <div class="flex items-center gap-3 max-w-lg mx-auto">
              <div class="flex-1 min-w-0">
                <p class="font-medium text-sm truncate"><%= @product.generated_title %></p>
                <p class="text-sm text-base-content/70">
                  <% if has_tiers %>
                    From <%= number_to_currency(@product.pricing_tiers.first["price"].to_f) %>
                  <% elsif @product.pac_size && @product.pac_size > 1 %>
                    <%= number_to_currency(@product.price) %> / pack of <%= number_with_delimiter(@product.pac_size) %>
                  <% else %>
                    <%= number_to_currency(@product.price) %>
                  <% end %>
                </p>
              </div>
              <button type="submit" form="add-to-cart-form" class="btn btn-primary btn-sm flex-shrink-0">
                Add to Cart
              </button>
            </div>
          </div>

        </div>
      </div>

      <%# Product Details Section %>
      <% if @product.description_detailed_with_fallback.present? %>
        <div class="mt-12 space-y-8">
          <div class="prose max-w-none">
            <h2>Product Details</h2>
            <%= render_product_description(@product.description_detailed_with_fallback) %>
          </div>
        </div>
      <% end %>

      <%= render "products/specifications", product: @product %>

      <%# Shop More in Category Section %>
      <div class="mt-12 p-6 bg-base-200 rounded-lg">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h2 class="text-xl mb-1">Explore More <%= @category.name %></h2>
            <p class="text-base-content/70">Browse our full range of <%= @category.name.downcase %>.</p>
          </div>
          <%= link_to category_browse_path(@category), class: "btn btn-outline" do %>
            View All <%= @category.name %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          <% end %>
        </div>
      </div>

      <%# Related Products Section %>
      <% if @related_products.any? %>
        <div class="mt-12">
          <h2 class="text-2xl mb-6">Related Products</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <%= render partial: "products/card", collection: @related_products, as: :product %>
          </div>
        </div>
      <% end %>

    </div>
  </div>

  <%# Cart Drawer %>
  <div class="drawer-side z-50">
    <label for="cart-drawer" aria-label="Close cart drawer" class="drawer-overlay"></label>
    <div class="bg-base-200 text-base-content h-full w-80 p-4 flex flex-col">
      <%= render "shared/drawer_cart_content" %>
    </div>
  </div>

</div>
